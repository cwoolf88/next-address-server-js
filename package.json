{
  "name": "next-address-server-js",
  "version": "0.1.0",
  "description": "Secure server-side SDK for integrating with next-address-primary (REST + webhooks).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./embed": {
      "types": "./dist/embed/index.d.ts",
      "import": "./dist/embed/index.js"
    },
    "./embed/widget.css": "./dist/embed/widget.css"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "tsc && cp src/embed/widget.css dist/embed/widget.css",
    "prepublishOnly": "npm run build",
    "sync:demo": "node ./scripts/sync-demo.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "next-address",
    "webhook",
    "address",
    "contacts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/next-address-server-js.git"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.6.3"
  }
}
